---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import EntryList from '../components/EntryList.astro';

const writing = (await getCollection('writing', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const projects = (await getCollection('projects', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);
---

<BaseLayout>
  <section class="section">
    <div class="intro-grid">
      <div>
        <p class="eyebrow">Laravel/PHP backend engineer and research software builder</p>
        <h1>I build backend systems for research workflows, scholarly data, and domain-heavy products.</h1>
        <p class="lede">
          My active public work is Nexus Scholar: a Laravel/PHP ecosystem for systematic reviews,
          citation graphs, reference management, and auditable research workflows. I also take on
          focused Laravel backend contracts to fund and sharpen that research work.
        </p>
        <div class="actions">
          <a class="button" href="/projects/nexus-scholar/">Open Nexus Scholar</a>
          <a class="button secondary" href="/writing/why-nexus-scholar-laravel-php/">Read the technical note</a>
        </div>
      </div>
      <figure class="system-visual">
        <img src="/assets/nexus-workflow.svg" alt="Nexus Scholar workflow map connecting core, CLI, web, graph packages, reference management, and evidence artifacts." />
      </figure>
    </div>

    <div class="note-strip" aria-label="Current focus areas">
      <div>
        <strong>Nexus Scholar</strong>
        <span>Core package, CLI workspace, web shell, graph packages, and reference tooling.</span>
      </div>
      <div>
        <strong>Contract Work</strong>
        <span>Laravel APIs, SaaS MVPs, integrations, package boundaries, and workflow infrastructure.</span>
      </div>
      <div>
        <strong>Research Boundary</strong>
        <span>Plant-disease AI is public only at a benchmark-safe level; unpublished methods stay controlled.</span>
      </div>
    </div>
  </section>

  <section class="section tight">
    <p class="eyebrow">Writing</p>
    <h2>Technical notes tied to real work</h2>
    <EntryList entries={writing} basePath="writing" />
  </section>

  <section class="section tight">
    <p class="eyebrow">Projects</p>
    <h2>Curated public work</h2>
    <EntryList entries={projects} basePath="projects" />
  </section>
</BaseLayout>
